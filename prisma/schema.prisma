// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin User ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   // Hashed password for credentials login
  emailVerified DateTime?
  image         String?
  role          Role      @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Blog Posts ───────────────────────────────────────────────

model Post {
  id          String      @id @default(cuid())
  title       String
  titleUz     String?     // Uzbek title
  slug        String      @unique
  excerpt     String?     @db.Text
  excerptUz   String?     @db.Text
  content     String      @db.Text  // HTML from Tiptap
  contentUz   String?     @db.Text
  coverImage  String?     // Cloudinary URL
  status      PostStatus  @default(DRAFT)
  featured    Boolean     @default(false)
  views       Int         @default(0)
  readingTime Int?        // minutes, auto-calculated
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tags        PostTag[]

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@map("posts")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  nameUz    String?
  slug      String    @unique
  color     String?   // hex color for badge
  createdAt DateTime  @default(now())

  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ─── Projects ─────────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  title        String
  titleUz      String?
  slug         String        @unique
  description  String        @db.Text
  descriptionUz String?      @db.Text
  content      String?       @db.Text  // detailed case study
  coverImage   String?
  images       String[]      // array of Cloudinary URLs
  techStack    String[]      // ["Python", "FastAPI", "PostgreSQL"]
  githubUrl    String?
  liveUrl      String?
  status       ProjectStatus @default(COMPLETED)
  featured     Boolean       @default(false)
  order        Int           @default(0)  // for manual ordering
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([slug])
  @@index([featured])
  @@map("projects")
}

// ─── Contact Messages ─────────────────────────────────────────

model Message {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String?
  body      String        @db.Text
  status    MessageStatus @default(UNREAD)
  ip        String?
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@map("messages")
}

// ─── Visitor Analytics ────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  country   String?
  device    String?  // "mobile" | "desktop" | "tablet"
  browser   String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@map("page_views")
}

// ─── Site Settings ────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─── Enums ────────────────────────────────────────────────────

enum Role {
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  SPAM
}
